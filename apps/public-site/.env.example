# ─── CMS ─────────────────────────────────────────────
# Optional. Production builds use Hygraph automatically; this flag is the dev opt-in.
VITE_USE_HYGRAPH=true

# Optional. Defaults to the project's published-content CDN URL (baked into the build).
# Override only for a different project (e.g. staging); set to "" to force mock data.
VITE_HYGRAPH_ENDPOINT=https://eu-west-2.cdn.hygraph.com/content/cmq1xlnd2022t07w9jmsfkk5o/master

# Hygraph Permanent Auth Token (only needed for draft/private content)
VITE_HYGRAPH_TOKEN=

# ─── Contact form ────────────────────────────────────
# URL of the deployed contact-worker (Cloudflare). When unset, the contact form
# stays in honest "not actually sent" mode (delivered=false).
VITE_CONTACT_WORKER_URL=

# ─── Anmälan (Supabase) — /anmal-dig3 demo + future live path ───────
# SERVER-SIDE only: read by api/submit.ts at runtime on Vercel. Deliberately
# NOT prefixed with VITE_ so the service-role key is never bundled into the
# client. Set these as Vercel Runtime env vars. When unset, /api/submit runs in
# honest "demo mode" (validates, does not persist). Required table:
# submissions — see the DDL in the api/submit.ts header comment.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

